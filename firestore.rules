// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: users
// Document ID: {userId}
// Fields:
//   - uid: string (required)
//   - email: string (required)
//   - displayName: string (required)
//   - photoURL: string (optional)
//   - createdAt: timestamp (optional)
//
// Collection: videos
// Document ID: {videoId}
// Fields:
//   - id: string (required)
//   - title: string (required)
//   - description: string (optional)
//   - category: string (optional)
//   - videoUrl: string (required)
//   - thumbnailUrl: string (required)
//   - authorId: string (required)
//   - authorName: string (required)
//   - authorPhotoUrl: string (optional)
//   - views: number (optional)
//   - likes: number (optional)
//   - createdAt: timestamp (optional)
//   - duration: string (optional)
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }
    
    function isValidStringLength(field, minLen, maxLen) {
      return request.resource.data[field] is string &&
        request.resource.data[field].size() >= minLen &&
        request.resource.data[field].size() <= maxLen;
    }
    
    function isValidUrl(url) {
      return url is string && (url.matches("^https://.*") || url.matches("^http://.*"));
    }
    
    function isValidUser(data) {
      return data.uid is string && data.uid == request.auth.uid &&
             data.email is string && data.email.size() > 0 && data.email.size() < 100 &&
             data.displayName is string && data.displayName.size() > 0 && data.displayName.size() < 50 &&
             (!('photoURL' in data) || (data.photoURL is string && data.photoURL.size() < 500)) &&
             (!('createdAt' in data) || data.createdAt is timestamp);
    }
    
    function isValidVideo(data) {
      return data.id is string && data.id.size() > 0 && data.id.size() < 100 &&
             data.title is string && data.title.size() > 0 && data.title.size() < 150 &&
             (!('description' in data) || (data.description is string && data.description.size() < 2000)) &&
             (!('category' in data) || (data.category is string && data.category.size() < 50)) &&
             data.videoUrl is string && data.videoUrl.size() < 1000 &&
             data.thumbnailUrl is string && data.thumbnailUrl.size() < 1000 &&
             data.authorId is string && data.authorId == request.auth.uid &&
             data.authorName is string && data.authorName.size() > 0 && data.authorName.size() < 50 &&
             (!('authorPhotoUrl' in data) || (data.authorPhotoUrl is string && data.authorPhotoUrl.size() < 500)) &&
             (!('views' in data) || data.views is number) &&
             (!('likes' in data) || data.likes is number) &&
             (!('createdAt' in data) || data.createdAt is timestamp) &&
             (!('duration' in data) || (data.duration is string && data.duration.size() < 20));
    }
    
    // ===============================================================
    // Rules
    // ===============================================================
    
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && hasRequiredFields(['uid', 'email', 'displayName']) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.uid == resource.data.uid;
    }
    
    match /videos/{videoId} {
      allow read: if true; // Publicly readable
      allow create: if isAuthenticated() && 
                    hasRequiredFields(['id', 'title', 'videoUrl', 'thumbnailUrl', 'authorId', 'authorName']) && 
                    isValidVideo(request.resource.data);
      allow update: if isAuthenticated() && 
                    (
                      // Owner can update everything
                      (isOwner(resource.data.authorId) && isValidVideo(request.resource.data) && request.resource.data.authorId == resource.data.authorId) ||
                      // Anyone can increment views
                      (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['views']) &&
                       request.resource.data.views == resource.data.views + 1)
                    );
      allow delete: if isOwner(resource.data.authorId);
    }
  }
}
