// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: users
// Collection: videos
// Collection: comments
// Collection: video_likes
// Collection: subscriptions
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isChannelOwner(channelId) {
      return isAuthenticated() && (
        channelId == request.auth.uid || 
        get(/databases/$(database)/documents/channels/$(channelId)).data.ownerId == request.auth.uid
      );
    }
    
    match /users/{userId} {
      allow read: if true;
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || 
                       (isAuthenticated() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['subscribers']));
    }
    
    match /videos/{videoId} {
      allow read: if true;
      allow create: if isChannelOwner(request.resource.data.authorId);
      allow update: if isChannelOwner(resource.data.authorId) ||
                       (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['views', 'likes', 'dislikes', 'ices']));
      allow delete: if isChannelOwner(resource.data.authorId);
    }

    match /comments/{commentId} {
      allow read: if true;
      allow create: if isChannelOwner(request.resource.data.authorId) || request.resource.data.authorId == 'anonymous';
      allow update: if isAuthenticated() && (
        // Author can edit their own comment
        (isChannelOwner(resource.data.authorId) && 
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['text', 'isEdited'])) ||
        
        // Any authenticated user can like/dislike
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes', 'dislikes'])) ||
        
        // Video author can heart the comment
        (isChannelOwner(get(/databases/$(database)/documents/videos/$(resource.data.videoId)).data.authorId) &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['authorHearted']))
      );
      allow delete: if isAuthenticated() && (
        isChannelOwner(resource.data.authorId) || 
        isChannelOwner(get(/databases/$(database)/documents/videos/$(resource.data.videoId)).data.authorId)
      );
    }

    match /video_likes/{likeId} {
      allow read: if true;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    match /video_ices/{iceId} {
      allow read: if true;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    match /subscriptions/{subId} {
      allow read: if true;
      allow create: if isAuthenticated() && request.resource.data.subscriberId == request.auth.uid;
      allow update: if isAuthenticated() && request.resource.data.subscriberId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.subscriberId == request.auth.uid;
    }

    match /playlists/{playlistId} {
      allow read: if true;
      allow create: if isChannelOwner(request.resource.data.authorId);
      allow update, delete: if isChannelOwner(resource.data.authorId);
    }

    match /community_posts/{postId} {
      allow read: if true;
      allow create: if isChannelOwner(request.resource.data.authorId);
      allow update: if isAuthenticated() && (
        isChannelOwner(resource.data.authorId) ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes', 'pollOptions'])
      );
      allow delete: if isChannelOwner(resource.data.authorId);
    }

    match /history/{historyId} {
      allow read: if isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    match /watch_later/{id} {
      allow read: if isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    match /favorites/{id} {
      allow read: if isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    match /hidden_channels/{id} {
      allow read: if isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    match /channels/{channelId} {
      allow read: if true;
      allow create: if isAuthenticated() && request.resource.data.ownerId == request.auth.uid;
      allow update: if isAuthenticated() && (
        channelId == request.auth.uid || 
        (exists(/databases/$(database)/documents/channels/$(channelId)) && resource.data.ownerId == request.auth.uid) ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['subscribers'])
      );
      allow delete: if isAuthenticated() && (channelId == request.auth.uid || resource.data.ownerId == request.auth.uid);
    }

    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    match /commentActions/{actionId} {
      allow read: if isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }
  }
}
