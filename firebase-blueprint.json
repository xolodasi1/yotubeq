{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "User account information and channel stats",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "photoURL": { "type": "string" },
        "subscribers": { "type": "number" },
        "bio": { "type": "string" },
        "joinedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "displayName", "email"]
    },
    "Video": {
      "title": "Video",
      "description": "Video metadata and analytics",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "thumbnailUrl": { "type": "string" },
        "videoUrl": { "type": "string" },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "authorPhotoUrl": { "type": "string" },
        "views": { "type": "number" },
        "likes": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "category": { "type": "string" },
        "duration": { "type": "string" }
      },
      "required": ["id", "title", "videoUrl", "authorId"]
    },
    "Comment": {
      "title": "Comment",
      "description": "Video comments",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "videoId": { "type": "string" },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "authorPhotoUrl": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "videoId", "authorId", "text"]
    }
  },
  "firestore": {
    "users": {
      "schema": "UserProfile",
      "description": "User profiles and channel data"
    },
    "videos": {
      "schema": "Video",
      "description": "All uploaded videos"
    },
    "comments": {
      "schema": "Comment",
      "description": "Comments on videos"
    }
  }
}
