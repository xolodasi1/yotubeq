{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The unique user ID"
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "User's email address"
        },
        "displayName": {
          "type": "string",
          "description": "User's display name"
        },
        "photoURL": {
          "type": "string",
          "description": "URL to the user's avatar"
        },
        "createdAt": {
          "type": "timestamp",
          "description": "When the user was created"
        }
      },
      "required": ["uid", "email", "displayName"]
    },
    "Video": {
      "title": "Video",
      "description": "A video uploaded by a user",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique video ID"
        },
        "title": {
          "type": "string",
          "description": "Title of the video"
        },
        "description": {
          "type": "string",
          "description": "Description of the video"
        },
        "category": {
          "type": "string",
          "description": "Category of the video"
        },
        "videoUrl": {
          "type": "string",
          "description": "URL to the video file in Firebase Storage"
        },
        "thumbnailUrl": {
          "type": "string",
          "description": "URL to the thumbnail image in Firebase Storage"
        },
        "authorId": {
          "type": "string",
          "description": "UID of the user who uploaded the video"
        },
        "authorName": {
          "type": "string",
          "description": "Display name of the author"
        },
        "authorPhotoUrl": {
          "type": "string",
          "description": "Photo URL of the author"
        },
        "views": {
          "type": "number",
          "description": "Number of views"
        },
        "likes": {
          "type": "number",
          "description": "Number of likes"
        },
        "ices": {
          "type": "number",
          "description": "Number of ices"
        },
        "createdAt": {
          "type": "timestamp",
          "description": "When the video was uploaded"
        },
        "duration": {
          "type": "string",
          "description": "Duration of the video"
        }
      },
      "required": ["id", "title", "videoUrl", "thumbnailUrl", "authorId", "authorName"]
    },
    "Playlist": {
      "title": "Playlist",
      "description": "A collection of videos",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "authorId": { "type": "string" },
        "videoIds": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "timestamp" }
      },
      "required": ["id", "title", "authorId", "videoIds"]
    },
    "CommunityPost": {
      "title": "CommunityPost",
      "description": "A post in the community tab",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "authorPhotoUrl": { "type": "string" },
        "text": { "type": "string" },
        "type": { "type": "string", "enum": ["text", "poll"] },
        "pollOptions": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "text": { "type": "string" },
              "votes": { "type": "number" },
              "voters": { "type": "array", "items": { "type": "string" } }
            }
          }
        },
        "createdAt": { "type": "timestamp" },
        "likes": { "type": "number" }
      },
      "required": ["id", "authorId", "text", "type"]
    },
    "History": {
      "title": "History",
      "description": "User's watch history",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "videoId": { "type": "string" },
        "watchedAt": { "type": "timestamp" }
      },
      "required": ["id", "userId", "videoId"]
    },
    "WatchLater": {
      "title": "WatchLater",
      "description": "Videos saved for later",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "videoId": { "type": "string" },
        "addedAt": { "type": "timestamp" }
      },
      "required": ["id", "userId", "videoId"]
    },
    "Favorite": {
      "title": "Favorite",
      "description": "Videos marked as favorite",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "videoId": { "type": "string" },
        "addedAt": { "type": "timestamp" }
      },
      "required": ["id", "userId", "videoId"]
    },
    "Notification": {
      "title": "Notification",
      "description": "User notifications for likes, comments, and subscriptions",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["like", "comment", "subscribe"] },
        "videoId": { "type": "string" },
        "videoTitle": { "type": "string" },
        "fromUserId": { "type": "string" },
        "fromUserName": { "type": "string" },
        "fromUserAvatar": { "type": "string" },
        "commentText": { "type": "string" },
        "createdAt": { "type": "timestamp" },
        "read": { "type": "boolean" }
      },
      "required": ["userId", "type", "fromUserId", "fromUserName", "createdAt", "read"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles"
    },
    "/videos/{videoId}": {
      "schema": { "$ref": "#/entities/Video" },
      "description": "Uploaded videos"
    },
    "/playlists/{playlistId}": {
      "schema": { "$ref": "#/entities/Playlist" },
      "description": "User playlists"
    },
    "/community_posts/{postId}": {
      "schema": { "$ref": "#/entities/CommunityPost" },
      "description": "Community posts"
    },
    "/history/{historyId}": {
      "schema": { "$ref": "#/entities/History" },
      "description": "Watch history"
    },
    "/watch_later/{id}": {
      "schema": { "$ref": "#/entities/WatchLater" },
      "description": "Watch later list"
    },
    "/favorites/{id}": {
      "schema": { "$ref": "#/entities/Favorite" },
      "description": "Favorite videos"
    },
    "/notifications/{notificationId}": {
      "schema": { "$ref": "#/entities/Notification" },
      "description": "User notifications"
    }
  }
}
